# Database
# Get this from your Neon database connection string
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL="postgresql://..."

# NextAuth Configuration
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET="your-generated-secret-here"

# Google OAuth Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Google Calendar API Configuration
# Create a service account in Google Cloud Console and enable Calendar API
# Get the service account email and private key from the service account JSON file
# Calendar ID is the calendar you want to use (use 'primary' for the main calendar)
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project-id.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID="primary"

# Application URL
# Used for generating links in calendar events
NEXT_PUBLIC_APP_URL="https://pawn-tracker.vercel.app"

# Automated Backup Configuration (Optional)
# Sign up at https://resend.com (free tier: 3000 emails/month)
# Get your API key from the Resend dashboard
RESEND_API_KEY="re_xxxxxxxxxx"

# Email address to receive automated backups (defaults to user's email)
BACKUP_EMAIL="your-email@example.com"# From email for backup notifications (requires verified domain in Resend)
# Use default 'onboarding@resend.dev' for testing
RESEND_FROM_EMAIL="Pawn Tracker <backups@yourdomain.com>"

# Cron secret for securing the backup endpoint (auto-generated by Vercel)
# You can also set this manually for local testing
CRON_SECRET="your-cron-secret"
